# =============================================================================
# Lighting Source TX — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored. NEVER commit real secrets.
# On Vercel, set these under Project Settings → Environment Variables.
# =============================================================================

# --- Go High Level (lead capture) -------------------------------------------
# Inbound webhook URL from your GHL workflow ("Inbound Webhook" trigger).
# Server-side only. Leave blank in development — forms will log the payload
# to the server console and still show the success state, so you can build
# and test without it. Set it in Vercel to start delivering real leads.
GHL_WEBHOOK_URL=

# --- Sanity CMS (projects, case studies, team) ------------------------------
# From sanity.io → your project → Settings → API.
# Leave these blank and the site serves built-in seed content (the 5 projects,
# 4 case studies, and team roster shipped in src/lib/seed). Fill them in to
# manage content from Sanity Studio instead.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Read token for private datasets / draft previews (server-side only).
# Not required if your dataset is public.
SANITY_API_READ_TOKEN=

# --- Site ---------------------------------------------------------------------
# Canonical site URL, used for sitemap.xml, robots.txt, and absolute OG URLs.
NEXT_PUBLIC_SITE_URL=https://www.lightingsourcetx.com
